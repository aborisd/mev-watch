# Ethereum RPC (Alchemy, QuickNode, Infura, Ankr — anything with WS)
# Example: wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ETH_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/REPLACE_ME
ETH_HTTP_URL=https://eth-mainnet.g.alchemy.com/v2/REPLACE_ME

# Postgres
POSTGRES_USER=mev
POSTGRES_PASSWORD=mev_change_me
POSTGRES_DB=mev_watch
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Derived DSN (compose passes this to backend services)
DATABASE_URL=postgresql://mev:mev_change_me@postgres:5432/mev_watch

# Ingester
INGESTER_WORKERS=4
# Confirmations before a block is considered final (reorg protection)
BLOCK_CONFIRMATIONS=2
# Backfill depth in blocks (0 = disabled). 50000 ≈ 7 days on mainnet.
BACKFILL_BLOCKS=0

# Detector
DETECTOR_INTERVAL_SEC=10
# Minimum net profit USD to persist a detected event (filter noise)
MIN_NET_PROFIT_USD=1.0

# API
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=*

# Caddy — domain for production HTTPS. Use :80 for local.
CADDY_DOMAIN=:80
